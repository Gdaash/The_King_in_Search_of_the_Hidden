--- !u!114 &903983344
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 903983342}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 28c3a9d28d87431c84a64698ce23ef5c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  MainDialogPanel: {fileID: 903983342}
  BlurBackgroundImage: {fileID: 1203460991}
  CharacterImage: {fileID: 1471616796}
  DialogAnimator: {fileID: 1864640317}
  DialogAudio: {fileID: 1864640316}
  DialogText: {fileID: 2142348097}
  DialogBtn: {fileID: 1864640318}
  IsPlayOnStart: 0
  DialogStartEvent:
    m_PersistentCalls:
      m_Calls: []
  DialogEndEvent:
    m_PersistentCalls:
      m_Calls: []
  DialogContent:
  - LanguageKey: English
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 5e4f83fcc0bff8b4c8ac9f5850420842, type: 3}
      Value: Perhaps you could shoot a couple of boars in the forest? That should
        keep them going for a while.
      Event:
        m_PersistentCalls:
          m_Calls: []
  - LanguageKey: Chinese
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 5e4f83fcc0bff8b4c8ac9f5850420842, type: 3}
      Value: "\u6216\u8BB8\u60A8\u53EF\u4EE5\u53BB\u68EE\u6797\u91CC\u730E\u6740\u51E0\u5934\u91CE\u732A\uFF1F\u8FD9\u5E94\u8BE5\u80FD\u8BA9\u4ED6\u4EEC\u6491\u4E00\u6BB5\u65F6\u95F4\u3002"
      Event:
        m_PersistentCalls:
          m_Calls: []
  - LanguageKey: French
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 5e4f83fcc0bff8b4c8ac9f5850420842, type: 3}
      Value: "Peut-\xEAtre pourriez-vous abattre quelques sangliers dans la for\xEAt\_?
        Cela devrait les rassasier pour un temps."
      Event:
        m_PersistentCalls:
          m_Calls: []
  - LanguageKey: Russian
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 5e4f83fcc0bff8b4c8ac9f5850420842, type: 3}
      Value: "\u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C, \u0432\u044B
        \u043C\u043E\u0433\u043B\u0438 \u0431\u044B \u043F\u043E\u0434\u0441\u0442\u0440\u0435\u043B\u0438\u0442\u044C
        \u043F\u0430\u0440\u0443 \u043A\u0430\u0431\u0430\u043D\u043E\u0432 \u0432
        \u043B\u0435\u0441\u0443? \u042D\u0442\u043E\u0433\u043E \u0434\u043E\u043B\u0436\u043D\u043E
        \u0445\u0432\u0430\u0442\u0438\u0442\u044C \u043D\u0430 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
        \u0432\u0440\u0435\u043C\u044F."
      Event:
        m_PersistentCalls:
          m_Calls: []
