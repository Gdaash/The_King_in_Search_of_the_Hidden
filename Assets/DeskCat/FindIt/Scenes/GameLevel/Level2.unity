      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 9008708229994426669, guid: 3966b132c92fe434097979961b6c444d, type: 3}
      propertyPath: DialogContent.Array.data[0].Value.Array.data[0].Value
      value: My king, the barns are out of food. The hungry peasants are threatening
        to revolt.
      objectReference: {fileID: 0}
    - target: {fileID: 9008708229994426669, guid: 3966b132c92fe434097979961b6c444d, type: 3}
      propertyPath: DialogContent.Array.data[1].Value.Array.data[0].Value
      value: "\u6211\u7684\u56FD\u738B\uFF0C\u7CAE\u4ED3\u7A7A\u4E86\u3002\u9965\u997F\u7684\u519C\u6C11\u4EEC\u6B63\u5A01\u80C1\u8981\u8D77\u4E49\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 9008708229994426669, guid: 3966b132c92fe434097979961b6c444d, type: 3}
      propertyPath: DialogContent.Array.data[2].Value.Array.data[0].Value
      value: "Mon roi, les greniers sont vides. Les paysans affam\xE9s menacent de
        se r\xE9volter."
      objectReference: {fileID: 0}
    - target: {fileID: 9008708229994426669, guid: 3966b132c92fe434097979961b6c444d, type: 3}
      propertyPath: DialogContent.Array.data[3].Value.Array.data[0].Value
      value: "\u041C\u043E\u0439 \u043A\u043E\u0440\u043E\u043B\u044C, \u0432 \u0430\u043C\u0431\u0430\u0440\u0430\u0445
        \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u0430\u0441\u044C \u0435\u0434\u0430.
        \u0413\u043E\u043B\u043E\u0434\u043D\u044B\u0435 \u043A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0435
        \u0433\u0440\u043E\u0437\u044F\u0442\u0441\u044F \u043F\u043E\u0434\u043D\u044F\u0442\u044C
        \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0438\u0435."
      objectReference: {fileID: 0}
