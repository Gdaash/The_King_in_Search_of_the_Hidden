    - target: {fileID: 9008708229994426669, guid: 3966b132c92fe434097979961b6c444d, type: 3}
      propertyPath: DialogContent.Array.data[1].Value.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 9008708229994426669, guid: 3966b132c92fe434097979961b6c444d, type: 3}
