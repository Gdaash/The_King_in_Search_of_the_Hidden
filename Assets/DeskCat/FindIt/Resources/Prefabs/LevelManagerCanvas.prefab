  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 28c3a9d28d87431c84a64698ce23ef5c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  MainDialogPanel: {fileID: 0}
  BlurBackgroundImage: {fileID: 2289948163119466123}
  CharacterImage: {fileID: 1715007457151276564}
  DialogAnimator: {fileID: 5456219854955521357}
  DialogAudio: {fileID: 1654605801311559407}
  DialogText: {fileID: 8393392630090804024}
  DialogBtn: {fileID: 3708250940769889362}
  IsPlayOnStart: 1
  DialogStartEvent:
    m_PersistentCalls:
      m_Calls: []
  DialogEndEvent:
    m_PersistentCalls:
      m_Calls: []
  DialogContent:
  - LanguageKey: English
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 26cbf381d9e6b644890103b345fecd3f, type: 3}
      Value: First, find the most basic monsters. Then we'll talk about their evolution.
      Event:
        m_PersistentCalls:
          m_Calls: []
  - LanguageKey: Chinese
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 26cbf381d9e6b644890103b345fecd3f, type: 3}
      Value: "\u9996\u5148\uFF0C\u6211\u4EEC\u6765\u627E\u51FA\u6700\u57FA\u672C\u7684\u602A\u7269\u3002\u7136\u540E\u6211\u4EEC\u518D\u6765\u8BA8\u8BBA\u5B83\u4EEC\u7684\u8FDB\u5316\u3002"
      Event:
        m_PersistentCalls:
          m_Calls: []
  - LanguageKey: French
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 26cbf381d9e6b644890103b345fecd3f, type: 3}
      Value: "Commen\xE7ons par trouver les monstres les plus basiques. Ensuite,
        nous parlerons de leur \xE9volution."
      Event:
        m_PersistentCalls:
          m_Calls: []
  - LanguageKey: Russian
    Value:
    - CharacterSprite: {fileID: 21300000, guid: 26cbf381d9e6b644890103b345fecd3f, type: 3}
      Value: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0430\u0439\u0434\u0435\u043C
        \u0441\u0430\u043C\u044B\u0445 \u043F\u0440\u043E\u0441\u0442\u044B\u0445
        \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432. \u0417\u0430\u0442\u0435\u043C
        \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u043C \u043E\u0431 \u0438\u0445
        \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u0438."
      Event:
        m_PersistentCalls:
          m_Calls: []
